# ── JobGati Backend Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in the values.

# Server config
PORT=5000

# MongoDB connection string
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/jobgati?retryWrites=true&w=majority

# JWT secret — use a long random string, e.g. generated with: openssl rand -hex 64
JWT_SECRET=your_super_secret_jwt_key_here

# JWT expiry
JWT_EXPIRES_IN=7d

# Google Gemini API key (for AI interview & learning path generation)
# Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# (Optional) OpenAI / Grok fallback
OPENAI_API_KEY=

# CORS allowed origin (your frontend URL)
CLIENT_URL=http://localhost:5173
